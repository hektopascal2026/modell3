# Nur scenarios.php erlauben — Config-Dateien nicht öffentlich
<FilesMatch "^(config\.local\.php|config\.example\.php)$">
  <IfModule mod_authz_core.c>
    Require all denied
  </IfModule>
  <IfModule !mod_authz_core.c>
    Order deny,allow
    Deny from all
  </IfModule>
</FilesMatch>

<IfModule mod_authz_core.c>
  Require all granted
</IfModule>
