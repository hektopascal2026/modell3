# --- Deploy-Pfad (Build) ---
# Dieses Repo deployt nach /modell3/ auf seismo.live
VITE_BASE_PATH=/modell3/

# --- Shared Hosting (empfohlen für Production) ---
# API-Key muss mit public/api/config.local.php auf dem Server übereinstimmen.
VITE_SCENARIO_API_KEY=
# VITE_SCENARIO_API_URL=/modell3/api/scenarios.php

# --- GitHub (optional, nur für lokale Entwicklung) ---
# PAT (classic) mit repo-Schreibrecht auf hektopascal2026/modell3
VITE_GITHUB_SCENARIO_TOKEN=
