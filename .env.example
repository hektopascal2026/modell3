# --- Deploy-Pfad (Build) ---
# Dieses Repo deployt nach /modell4/ auf seismo.live
VITE_BASE_PATH=/modell4/

# --- Shared Hosting (empfohlen für Production) ---
# API-Key muss mit public/api/config.local.php auf dem Server übereinstimmen.
# URL optional — Standard: {BASE_URL}api/scenarios.php (z. B. /modell4/api/scenarios.php)
VITE_SCENARIO_API_KEY=
# VITE_SCENARIO_API_URL=/modell4/api/scenarios.php

# --- GitHub (optional, nur für lokale Entwicklung) ---
# PAT (classic) mit repo-Schreibrecht auf hektopascal2026/modell4
VITE_GITHUB_SCENARIO_TOKEN=
